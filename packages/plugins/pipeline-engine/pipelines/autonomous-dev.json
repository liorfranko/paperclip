{
  "name": "autonomous-dev",
  "version": 7,
  "description": "Full autonomous development pipeline — triage → validate → plan → implement → review (7 specialized reviewers) → gate → simplify → validate",
  "trigger": { "label": "pipeline:autonomous-dev" },
  "stages": [
    { "id": "triage", "type": "stage", "agent_role": "pipe-generic", "actionId": "triage-new-issues" },
    { "id": "bug-triage", "type": "stage", "agent_role": "pipe-generic", "actionId": "triage-new-issues" },
    { "id": "fast-track-triage", "type": "stage", "agent_role": "pipe-generic", "actionId": "triage-new-issues" },
    { "id": "valid-scenario", "type": "stage", "agent_role": "pipe-generic", "actionId": "validate-scenario" },
    { "id": "escalate-scenario", "type": "block", "reason": "No holdout scenario found for this feature. Add a scenario YAML to `.paperclip/scenarios/` and unblock to resume." },
    { "id": "create-spec", "type": "stage", "agent_role": "pipe-generic", "actionId": "create-spec" },
    { "id": "valid-spec", "type": "stage", "agent_role": "pipe-generic", "actionId": "validate-spec" },
    { "id": "escalate-spec", "type": "block", "reason": "Design spec missing or incomplete. Add a spec to `docs/specs/` covering architecture, data flow, error handling, testing, and Definition of Done, then unblock to resume." },
    { "id": "plan-tasks", "type": "fan_out", "agent_role": "pipe-generic", "actionId": "plan-tasks" },
    { "id": "write-backend-tests", "type": "stage", "agent_role": "pipe-backend", "actionId": "write-tests" },
    { "id": "write-backend-impl", "type": "stage", "agent_role": "pipe-backend", "actionId": "write-implementation" },
    { "id": "de-slop-backend", "type": "stage", "agent_role": "pipe-backend", "actionId": "de-slop-verify" },
    { "id": "write-frontend-tests", "type": "stage", "agent_role": "pipe-frontend", "actionId": "write-tests" },
    { "id": "write-frontend-impl", "type": "stage", "agent_role": "pipe-frontend", "actionId": "write-implementation" },
    { "id": "de-slop-frontend", "type": "stage", "agent_role": "pipe-frontend", "actionId": "de-slop-verify" },
    { "id": "sync-impl", "type": "fan_in" },
    { "id": "open-pr", "type": "stage", "agent_role": "pipe-pr-manager", "actionId": "open-pr" },
    { "id": "check-ci", "type": "fan_out", "agent_role": "pipe-pr-manager", "actionId": "check-ci" },
    { "id": "fix-ci-backend", "type": "stage", "agent_role": "pipe-backend", "actionId": "fix-ci" },
    { "id": "fix-ci-frontend", "type": "stage", "agent_role": "pipe-frontend", "actionId": "fix-ci" },
    { "id": "ci-fix-sync", "type": "fan_in" },
    { "id": "dispatch-reviews", "type": "fan_out", "agent_role": "pipe-reviewer", "actionId": "dispatch-code-reviews" },

    { "id": "review-code-quality", "type": "stage", "agent_role": "pipe-reviewer", "actionId": "review-code-quality" },
    { "id": "review-error-handling", "type": "stage", "agent_role": "pipe-reviewer", "actionId": "review-error-handling" },
    { "id": "review-test-coverage", "type": "stage", "agent_role": "pipe-reviewer", "actionId": "review-test-coverage" },
    { "id": "review-comments", "type": "stage", "agent_role": "pipe-reviewer", "actionId": "review-comments" },
    { "id": "review-type-design", "type": "stage", "agent_role": "pipe-reviewer", "actionId": "review-type-design" },
    { "id": "review-architecture", "type": "stage", "agent_role": "pipe-reviewer", "actionId": "review-architecture" },
    { "id": "review-blind-validation", "type": "stage", "agent_role": "pipe-reviewer", "actionId": "review-blind-validation" },

    { "id": "review-sync", "type": "fan_in" },
    { "id": "evaluate-findings", "type": "stage", "agent_role": "pipe-generic", "actionId": "evaluate-critical-findings" },
    { "id": "simplify-code", "type": "stage", "agent_role": "pipe-backend", "actionId": "simplify-code" },
    { "id": "scenario-validator", "type": "stage", "agent_role": "pipe-validator", "actionId": "validate-scenario-result" },
    { "id": "escalate-validation", "type": "block", "reason": "Scenario validation failed after maximum retries. Manual intervention required — review implementation and holdout scenario." }
  ],
  "edges": [
    { "id": "e-triage-bug", "from": "triage", "to": "bug-triage", "sourceHandle": "bug" },
    { "id": "e-triage-feature", "from": "triage", "to": "valid-scenario", "sourceHandle": "feature" },
    { "id": "e-triage-fast", "from": "triage", "to": "fast-track-triage", "sourceHandle": "fast-track" },

    { "id": "e-scenario-yes", "from": "valid-scenario", "to": "create-spec", "sourceHandle": "yes" },
    { "id": "e-scenario-no", "from": "valid-scenario", "to": "escalate-scenario", "sourceHandle": "no" },

    { "id": "e-create-spec-done", "from": "create-spec", "to": "valid-spec", "sourceHandle": "done" },

    { "id": "e-spec-yes", "from": "valid-spec", "to": "plan-tasks", "sourceHandle": "yes" },
    { "id": "e-spec-no", "from": "valid-spec", "to": "escalate-spec", "sourceHandle": "no" },

    { "id": "e-plan-backend", "from": "plan-tasks", "to": "write-backend-tests", "activationKey": "backend" },
    { "id": "e-plan-frontend", "from": "plan-tasks", "to": "write-frontend-tests", "activationKey": "frontend" },

    { "id": "e-be-tests-impl", "from": "write-backend-tests", "to": "write-backend-impl", "sourceHandle": "done" },
    { "id": "e-be-impl-deslop", "from": "write-backend-impl", "to": "de-slop-backend", "sourceHandle": "done" },
    { "id": "e-be-deslop-sync", "from": "de-slop-backend", "to": "sync-impl", "sourceHandle": "done" },

    { "id": "e-fe-tests-impl", "from": "write-frontend-tests", "to": "write-frontend-impl", "sourceHandle": "done" },
    { "id": "e-fe-impl-deslop", "from": "write-frontend-impl", "to": "de-slop-frontend", "sourceHandle": "done" },
    { "id": "e-fe-deslop-sync", "from": "de-slop-frontend", "to": "sync-impl", "sourceHandle": "done" },

    { "id": "e-sync-pr", "from": "sync-impl", "to": "open-pr" },
    { "id": "e-pr-checkci", "from": "open-pr", "to": "check-ci", "sourceHandle": "done" },
    { "id": "e-ci-pass", "from": "check-ci", "to": "dispatch-reviews", "activationKey": "pass" },
    { "id": "e-ci-backend", "from": "check-ci", "to": "fix-ci-backend", "activationKey": "backend" },
    { "id": "e-ci-frontend", "from": "check-ci", "to": "fix-ci-frontend", "activationKey": "frontend" },
    { "id": "e-fixbe-sync", "from": "fix-ci-backend", "to": "ci-fix-sync", "sourceHandle": "done" },
    { "id": "e-fixfe-sync", "from": "fix-ci-frontend", "to": "ci-fix-sync", "sourceHandle": "done" },
    { "id": "e-cisync-recheck", "from": "ci-fix-sync", "to": "check-ci", "type": "loop", "max_iterations": 3, "label": "CI fix loop (max 3)" },

    { "id": "e-reviews-code-quality", "from": "dispatch-reviews", "to": "review-code-quality", "activationKey": "code-quality" },
    { "id": "e-reviews-error-handling", "from": "dispatch-reviews", "to": "review-error-handling", "activationKey": "error-handling" },
    { "id": "e-reviews-test-coverage", "from": "dispatch-reviews", "to": "review-test-coverage", "activationKey": "test-coverage" },
    { "id": "e-reviews-comments", "from": "dispatch-reviews", "to": "review-comments", "activationKey": "comment-quality" },
    { "id": "e-reviews-type-design", "from": "dispatch-reviews", "to": "review-type-design", "activationKey": "type-design" },
    { "id": "e-reviews-architecture", "from": "dispatch-reviews", "to": "review-architecture", "activationKey": "architecture" },
    { "id": "e-reviews-blind-validation", "from": "dispatch-reviews", "to": "review-blind-validation", "activationKey": "blind-validation" },

    { "id": "e-rq-sync", "from": "review-code-quality", "to": "review-sync" },
    { "id": "e-reh-sync", "from": "review-error-handling", "to": "review-sync" },
    { "id": "e-rtc-sync", "from": "review-test-coverage", "to": "review-sync" },
    { "id": "e-rc-sync", "from": "review-comments", "to": "review-sync" },
    { "id": "e-rtd-sync", "from": "review-type-design", "to": "review-sync" },
    { "id": "e-ra-sync", "from": "review-architecture", "to": "review-sync" },
    { "id": "e-rbv-sync", "from": "review-blind-validation", "to": "review-sync" },

    { "id": "e-sync-evaluate", "from": "review-sync", "to": "evaluate-findings" },

    { "id": "e-findings-pass", "from": "evaluate-findings", "to": "simplify-code", "sourceHandle": "pass" },
    { "id": "e-findings-fail-impl", "from": "evaluate-findings", "to": "write-backend-impl", "sourceHandle": "fail-impl", "type": "loop", "max_iterations": 3, "label": "revision loop (max 3)" },

    { "id": "e-simplify-done", "from": "simplify-code", "to": "scenario-validator" },

    { "id": "e-validator-invalid", "from": "scenario-validator", "to": "escalate-validation", "sourceHandle": "not-valid" }
  ],
  "positions": {
    "triage": { "x": 400, "y": 0 },
    "bug-triage": { "x": 100, "y": 180 },
    "valid-scenario": { "x": 400, "y": 180 },
    "fast-track-triage": { "x": 700, "y": 180 },
    "escalate-scenario": { "x": 700, "y": 360 },
    "create-spec": { "x": 400, "y": 360 },
    "valid-spec": { "x": 400, "y": 540 },
    "escalate-spec": { "x": 700, "y": 720 },
    "plan-tasks": { "x": 400, "y": 720 },
    "write-backend-tests": { "x": 200, "y": 920 },
    "write-backend-impl": { "x": 200, "y": 1100 },
    "de-slop-backend": { "x": 200, "y": 1280 },
    "write-frontend-tests": { "x": 600, "y": 920 },
    "write-frontend-impl": { "x": 600, "y": 1100 },
    "de-slop-frontend": { "x": 600, "y": 1280 },
    "sync-impl": { "x": 400, "y": 1460 },
    "open-pr": { "x": 400, "y": 1620 },
    "check-ci": { "x": 400, "y": 1800 },
    "fix-ci-backend": { "x": 200, "y": 1980 },
    "fix-ci-frontend": { "x": 600, "y": 1980 },
    "ci-fix-sync": { "x": 400, "y": 2160 },
    "dispatch-reviews": { "x": 400, "y": 2340 },
    "review-code-quality": { "x": 0, "y": 2540 },
    "review-error-handling": { "x": 140, "y": 2540 },
    "review-test-coverage": { "x": 280, "y": 2540 },
    "review-comments": { "x": 420, "y": 2540 },
    "review-type-design": { "x": 560, "y": 2540 },
    "review-architecture": { "x": 700, "y": 2540 },
    "review-blind-validation": { "x": 840, "y": 2540 },
    "review-sync": { "x": 400, "y": 2740 },
    "evaluate-findings": { "x": 400, "y": 2920 },
    "simplify-code": { "x": 400, "y": 3100 },
    "scenario-validator": { "x": 400, "y": 3280 },
    "escalate-validation": { "x": 700, "y": 3280 }
  }
}
